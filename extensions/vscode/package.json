{
  "name": "multiplayer-code-bridge",
  "displayName": "Multiplayer Code Bridge",
  "description": "VS Code bridge for standalone Multiplayer Code desktop sessions",
  "version": "0.1.4",
  "publisher": "local-prototype",
  "repository": {
    "type": "git",
    "url": "https://github.com/RockyWearsAHat/multiplayer-ides.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "files": [
    "src/**",
    "media/**",
    "node_modules/**",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "multiplayer",
          "title": "Multiplayer",
          "icon": "media/icon-people-centered.svg"
        }
      ]
    },
    "views": {
      "multiplayer": [
        {
          "type": "webview",
          "id": "multiplayer.sidePanel",
          "name": "Multiplayer"
        }
      ]
    },
    "commands": [
      {
        "command": "multiplayer.easyStart",
        "title": "Multiplayer: Start Live Collaboration",
        "category": "Multiplayer"
      },
      {
        "command": "multiplayer.hostSession",
        "title": "Host Session",
        "category": "Multiplayer"
      },
      {
        "command": "multiplayer.joinSession",
        "title": "Join Session",
        "category": "Multiplayer"
      },
      {
        "command": "multiplayer.openPanel",
        "title": "Open Multiplayer Panel",
        "category": "Multiplayer"
      },
      {
        "command": "multiplayer.toggleInviteOnly",
        "title": "Toggle Invite Policy",
        "category": "Multiplayer"
      },
      {
        "command": "multiplayer.endSession",
        "title": "End Session",
        "category": "Multiplayer"
      }
    ]
  },
  "scripts": {
    "watch": "echo \"Use F5 in Extension Development Host for this prototype\"",
    "lint": "echo \"No lint configured\"",
    "package": "node ./scripts/package-vsix.js"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.1"
  }
}
